{
  "expo": {
    "name": "GreenBD",
    "slug": "GreenBD",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "greenbd",
    "userInterfaceStyle": "automatic",
    "entryPoint": "./src/app/_layout.tsx",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#006A4E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.greenbd.app",
      "infoPlist": {
        "NSCameraUsageDescription": "GreenBD needs camera access to capture eco-friendly activities",
        "NSPhotoLibraryUsageDescription": "GreenBD needs photo library access to select images",
        "NSLocationWhenInUseUsageDescription": "GreenBD needs location to verify activity locations",
        "NSMicrophoneUsageDescription": "GreenBD needs microphone access for voice input"
      }
    },
    "android": {
      "package": "com.greenbd.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#006A4E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-location",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "GreenBD needs access to your photos to upload eco-activity images"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#006A4E"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow GreenBD to use Face ID for secure login"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "157a6c75-a754-421d-84e5-2686e95ea472"
      }
    }
  }
}
