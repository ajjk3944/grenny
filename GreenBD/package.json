{
  "name": "greenbd",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "npx expo start",
    "dev:android": "npx expo run:android",
    "dev:ios": "npx expo run:ios",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "node scripts/build-android.js",
    "build:dev-apk": "eas build -p android --profile development",
    "build:preview-apk": "eas build -p android --profile preview",
    "build:prod": "eas build -p android --profile production",
    "build:ios": "eas build -p ios --profile production",
    "server:dev": "cd server && npm run dev",
    "server:build": "cd server && npm run build",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/native": "^7.1.33",
    "axios": "^1.13.6",
    "expo": "~55.0.8",
    "expo-av": "^16.0.8",
    "expo-background-fetch": "^55.0.10",
    "expo-camera": "^55.0.11",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.18",
    "expo-file-system": "^55.0.11",
    "expo-font": "~55.0.4",
    "expo-haptics": "^55.0.9",
    "expo-image": "~55.0.6",
    "expo-image-manipulator": "^55.0.11",
    "expo-image-picker": "^55.0.13",
    "expo-linear-gradient": "^55.0.9",
    "expo-linking": "~55.0.8",
    "expo-local-authentication": "^55.0.9",
    "expo-location": "^55.1.4",
    "expo-notifications": "^55.0.13",
    "expo-router": "~55.0.7",
    "expo-secure-store": "^55.0.9",
    "expo-speech": "^55.0.9",
    "expo-speech-recognition": "^3.1.2",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-task-manager": "^55.0.10",
    "expo-updates": "^55.0.13",
    "expo-web-browser": "~55.0.10",
    "i18next": "^25.10.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.6.6",
